PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Set to "false" if your cloud database uses a self-signed or private CA certificate (e.g. Neon, Render)
DB_SSL_REJECT_UNAUTHORIZED=false

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# Passwords — must be set in production (server will refuse to start otherwise)
ADMIN_PASSWORD=replace-with-strong-admin-password
ORDERS_SCREEN_PASSWORD=replace-with-strong-orders-password
DASHBOARD_SCREEN_PASSWORD=replace-with-strong-dashboard-password
